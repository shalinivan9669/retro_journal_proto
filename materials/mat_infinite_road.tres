[ext_resource type="Texture2D" path="res://assets/textures/tex_infinite_road_halftone.png" id="1_road_texture"]

[sub_resource type="Shader" id="Shader_infinite_road"]
code = "shader_type spatial;\nrender_mode unshaded;\n\nuniform sampler2D road_texture : source_color, repeat_enable, filter_nearest;\nuniform vec2 uv_offset = vec2(0.0, 0.0);\nuniform vec2 uv_scale = vec2(3.0, 24.0);\n\nvoid fragment() {\n\tvec2 road_uv = UV * uv_scale + uv_offset;\n\tALBEDO = texture(road_texture, road_uv).rgb;\n\tROUGHNESS = 1.0;\n}\n"

[resource]
shader = SubResource("Shader_infinite_road")
shader_parameter/road_texture = ExtResource("1_road_texture")
shader_parameter/uv_offset = Vector2(0, 0)
shader_parameter/uv_scale = Vector2(3, 24)
